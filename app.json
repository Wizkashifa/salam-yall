{
  "expo": {
    "name": "Salam Y'all",
    "slug": "salam-yall",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "salamyall",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2b1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.ummahconnect",
      "usesAppleSignIn": true,
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "buildNumber": "6",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to calculate prayer times and find the nearest masjid.",
        "UIBackgroundModes": ["remote-notification"]
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.app.ummahconnect"
        ],
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.salamyall",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "17.0"
          }
        }
      ],
      "./plugins/withPrayerTimesWidget"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
