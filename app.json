{
  "expo": {
    "name": "Salam Y'all",
    "slug": "salam-yall",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "salamyall",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2b1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.salamyall",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "buildNumber": "6",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to calculate prayer times and find the nearest masjid.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.salamyall",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withPrayerWidget"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "da3384a8-5d60-4efe-8e88-6c98202f6aeb"
      }
    },
    "owner": "wizkashifa"
  }
}
